<div style="
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
">
<%= form_with(model: word) do |form| %>
  <% if word.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(word.errors.count, "error") %> prohibited this word from being saved:</h2>

      <ul>
        <% word.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
<div style="
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
">
<span>
  <%= form.label :word, "word:" %>
  <%= form.text_field :word, {value: @word.word }%>
  </span>
  <span>
  <%= form.label :definition, "definition:" %>
  <%= form.text_field :definition, {value: @word.definition }%>
  </span>
  
  
</div>

  <div>
    <%= form.submit %>
  </div>
<% end %>