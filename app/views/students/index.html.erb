<style>
.students {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: start;
}

.student {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: start;
}
</style>

<h1>Students#index</h1>
<p>Find me in app/views/students/index.html.erb</p>

<div class="students">
    <% @students.each do |student| %>
        <div class="student">
            <%= student.email %>
            <%# student.name %>
            <%# student.level %>
            <%# student.invoicee %>
            <%# student.schedule %>
        </div>
    <% end %>
</div>